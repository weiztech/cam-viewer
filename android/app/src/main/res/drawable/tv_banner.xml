<?xml version="1.0" encoding="utf-8"?>
<!-- Android TV home screen banner (displayed in the Leanback launcher row).
     Renders as a 16:9 dark tile with the app icon centred.
     Replace with a proper 320x180 dp PNG if you want a custom artwork banner. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Match the app's dark background colour -->
    <item android:drawable="@color/tv_banner_bg" />
    <!-- App icon centred inside the banner tile -->
    <item>
        <bitmap
            android:src="@mipmap/ic_launcher"
            android:gravity="center" />
    </item>
</layer-list>
